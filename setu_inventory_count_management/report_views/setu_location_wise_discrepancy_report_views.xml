<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="setu_location_wise_discrepancy_report_list_view" model="ir.ui.view">
            <field name="name">setu.location.wise.discrepancy.report.tree</field>
            <field name="model">setu.location.wise.discrepancy.report</field>
            <field name="arch" type="xml">
                <list string="Location-wise Discrepancy Report">
                    <field name="location_id"/>
                    <field name="total_products_counted"/>
                    <field name="total_discrepancy_lines"/>
                    <field name="discrepancy_percent" widget="percentpie"/>
                </list>
            </field>
        </record>
        <record id="setu_location_wise_discrepancy_report_search_view" model="ir.ui.view">
            <field name="name">setu.location.wise.discrepancy.report.search</field>
            <field name="model">setu.location.wise.discrepancy.report</field>
            <field name="arch" type="xml">
                <search string="Location-wise Discrepancy Report">
                    <field name="location_id" string="Location"/>
                    <filter name="high_discrepancy"
                            string="High Discrepancy"
                            domain="[('discrepancy_percent', '&gt;', 50)]"/>
                    <filter name="no_discrepancy"
                            string="No Discrepancy"
                            domain="[('discrepancy_percent', '=', 0)]"/>
                </search>
            </field>
        </record>


        <record id="location_wise_discrepancy_report_action" model="ir.actions.act_window">
            <field name="name">Location-wise Discrepancy</field>
            <field name="res_model">setu.location.wise.discrepancy.report</field>
            <field name="view_mode">list</field>
            <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        </record>

        <menuitem id="menu_location_wise_discrepancy"
                  name="Location-wise Discrepancy"
                  parent="setu_inventory_count_management.setu_inventory_reporting_menu"
                  action="location_wise_discrepancy_report_action"
                  sequence="12"/>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_inventory_discrepancy_pivot" model="ir.ui.view">
            <field name="name">setu.inventory.count.pivot.report.pivot</field>
            <field name="model">setu.inventory.discrepancy.report</field>
            <field name="arch" type="xml">
                <pivot string="Inventory Count Pivot">
                    <field name="product_id" type="row"/>
                    <field name="discrepancy_percentage" type="measure"/>
                </pivot>
            </field>
        </record>
        <record id="setu_inventory_discrepancy_report_search" model="ir.ui.view">
            <field name="name">setu.inventory.discrepancy.report.search</field>
            <field name="model">setu.inventory.discrepancy.report</field>
            <field name="arch" type="xml">
                <search string="Inventory Discrepancy Report">
                    <field name="product_id"/>
                    <field name="date"/>
                    <field name="location_id"/>
                    <field name="approver_id"/>
                    <group>
                        <filter string="Product" name="group_product" context="{'group_by':'product_id'}"/>
                        <filter string="Date" name="group_date" context="{'group_by':'date'}"/>
                        <filter string="Location" name="group_location" context="{'group_by':'location_id'}"/>
                        <filter string="Approver" name="group_approver" context="{'group_by':'approver_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="setu_inventory_discrepancy_report_action" model="ir.actions.act_window">
            <field name="name">Inventory Discrepancy Report</field>
            <field name="res_model">setu.inventory.discrepancy.report</field>
            <field name="view_mode">pivot</field>
            <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        </record>

        <menuitem id="menu_inventory_count_pivot"
                  name="Inventory Discrepancy Report"
                  parent="setu_inventory_count_management.setu_inventory_reporting_menu"
                  action="setu_inventory_discrepancy_report_action"
                  sequence="5"/>

    </data>
</odoo>

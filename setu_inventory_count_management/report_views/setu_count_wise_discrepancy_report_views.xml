<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="setu_count_wise_discrepancy_report_list_view" model="ir.ui.view">
            <field name="name">setu.count.wise.discrepancy.report.list.view</field>
            <field name="model">setu.count.wise.discrepancy.report</field>
            <field name="arch" type="xml">
                <list string="Count-wise Discrepancy Report">
                    <field name="count_id"/>
                    <field name="total_count_lines"/>
                    <field name="discrepancy_lines"/>
                    <field name="discrepancy_percent" widget="percentpie"/>
                    <field name="company_id" column_invisible="1"/>
                </list>
            </field>
        </record>
        <record id="setu_count_wise_discrepancy_report_search_view" model="ir.ui.view">
            <field name="name">setu.count.wise.discrepancy.report.search</field>
            <field name="model">setu.count.wise.discrepancy.report</field>
            <field name="arch" type="xml">
                <search string="Count-wise Discrepancy Report">
                    <field name="count_id" string="Inventory Count"/>
                    <filter name="high_discrepancy"
                            string="High Discrepancy "
                            domain="[('discrepancy_percent', '>', 50)]"/>
                    <filter name="no_discrepancy"
                            string="No Discrepancy"
                            domain="[('discrepancy_lines', '=', 0)]"/>
                </search>
            </field>
        </record>


        <record id="count_wise_discrepancy_action" model="ir.actions.act_window">
            <field name="name">Count-wise Discrepancy</field>
            <field name="res_model">setu.count.wise.discrepancy.report</field>
            <field name="view_mode">list</field>
            <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        </record>

        <menuitem id="menu_count_wise_discrepancy"
                  name="Count-wise Discrepancy"
                  parent="setu_inventory_count_management.setu_inventory_reporting_menu"
                  action="count_wise_discrepancy_action"
                  sequence="10"/>
    </data>
</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_wise_discrepancy_report_list_view" model="ir.ui.view">
            <field name="name">setu.product.wise.discrepancy.report.list</field>
            <field name="model">setu.product.wise.discrepancy.report</field>
            <field name="arch" type="xml">
                <list string="Product-wise Discrepancy Report">
                    <field name="product_id"/>
                    <field name="company_id"/>
                    <field name="total_times_counted"/>
                    <field name="discrepancy_products"/>
                    <field name="discrepancy_percent" widget="percentpie"/>
                </list>
            </field>
        </record>
        <record id="product_wise_discrepancy_report_search_view" model="ir.ui.view">
            <field name="name">setu.product.wise.discrepancy.report.search</field>
            <field name="model">setu.product.wise.discrepancy.report</field>
            <field name="arch" type="xml">
                <search string="Product-wise Discrepancy Report">
                    <field name="product_id" string="Product"/>
                    <filter name="high_discrepancy"
                            string="High Discrepancy"
                            domain="[('discrepancy_percent', '&gt;', 50)]"/>
                    <filter name="no_discrepancy"
                            string="No Discrepancy"
                            domain="[('discrepancy_percent', '=', 0)]"/>
                </search>
            </field>
        </record>


        <record id="product_wise_discrepancy_report_action" model="ir.actions.act_window">
            <field name="name">Product-wise Discrepancy</field>
            <field name="res_model">setu.product.wise.discrepancy.report</field>
            <field name="view_mode">list</field>
            <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        </record>

        <menuitem id="menu_product_wise_discrepancy"
                  name="Product-wise Discrepancy"
                  parent="setu_inventory_count_management.setu_inventory_reporting_menu"
                  action="product_wise_discrepancy_report_action"
                  sequence="11"/>
    </data>
</odoo>

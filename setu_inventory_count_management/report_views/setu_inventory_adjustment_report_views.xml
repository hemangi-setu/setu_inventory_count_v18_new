<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="setu_inventory_adjustment_report_tree_view" model="ir.ui.view">
            <field name="name">setu.inventory.adjustment.report.tree.view</field>
            <field name="model">setu.inventory.adjustment.report</field>
            <field name="arch" type="xml">
                <list string="Inventory Session" create="0" edit="0" delete="0"
                      decoration-success="adjustment_type == 'IN'" decoration-danger="adjustment_type == 'OUT'">
                    <field name="count_id" widget="none" options="{'no_create': True, 'no_open':True}"/>
                    <field name="user_id" widget="none" string='Approver' options="{'no_create': True, 'no_open':True}"
                           column_invisible="1"/>
                    <field name="product_id" widget="none" options="{'no_create': True, 'no_open':True}"/>
                    <field name="location_id" widget="none" options="{'no_create': True, 'no_open':True}"/>
                    <field name="serial_number_names" widget="none" options="{'no_create': True, 'no_open':True}"/>
                    <field name="not_found_serial_number_names" widget="none"
                           options="{'no_create': True, 'no_open':True}"/>
                    <field name="lot_id" widget="none" options="{'no_create': True, 'no_open':True}"/>
                    <field name="warehouse_id" widget="none" options="{'no_create': True, 'no_open':True}"/>
                    <field name="inventory_count_date" widget="none" string="Adjustment Date"/>
                    <field name="theoretical_qty" widget="none"/>
                    <field name="counted_qty" widget="none"/>
                    <field name="discrepancy_qty" widget="none" string="Adjustment Qty"/>
                    <field name="discrepancy_value" widget="none" string="Adjustment value"/>
                    <field name="adjustment_type" widget="none"/>
                    <field name="is_overstock" column_invisible="1"/>
                    <field name="is_understock" column_invisible="1"/>
                </list>
            </field>
        </record>

        <record id="setu_inventory_adjustment_report_form_view" model="ir.ui.view">
            <field name="name">setu.inventory.adjustment.report.form.view</field>
            <field name="model">setu.inventory.adjustment.report</field>
            <field name="arch" type="xml">
                <form string="Inventory Adjustments">
                    <sheet>
                        <div style="margin-top:-15px;">
                            • Select the <strong>Location(s)</strong> and
                            <strong>User(s)</strong>
                            only if you want the data with specific location(s) and user(s).
                            <br/>
                            • Report will be generated based on selected <strong>Date Range</strong>.
                            Do not select the dates if you want all data report.
                        </div>
                        <group>
                            <group>
                                <field name="start_date"/>
                            </group>
                            <group>
                                <field name="end_date"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="location_ids" options="{'no_create': True, 'no_create_edit':True}"
                                       widget="many2many_tags"
                                       domain="[('usage', '=', 'internal')]"/>
                            </group>
                            <group>
                                <field name="user_ids" options="{'no_create': True, 'no_create_edit':True}"
                                       string="Approvers" widget="many2many_tags"/>
                            </group>
                        </group>

                    </sheet>
                    <footer>
                        <button name="generate_report" string="Generate" type="object" class="oe_highlight"/>
                    </footer>
                </form>
            </field>
        </record>


        <record id="setu_inventory_adjustment_report_action" model="ir.actions.act_window">
            <field name="name">Inventory Adjustment Report</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">setu.inventory.adjustment.report</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <record id="setu_inventory_adjustment_report_action_view" model="ir.actions.act_window">
            <field name="name">Inventory Adjustment Report</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">setu.inventory.adjustment.report</field>
            <field name="domain">[('warehouse_id.company_id', 'in', allowed_company_ids)]</field>
            <field name="view_mode">list</field>
            <field name="context">{'search_default_group_by_adjustment_type':1}</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face" style="margin-top:250px;">
                    There are no Inventory Adjustments for Inventory Counts.
                </p>
            </field>
        </record>

        <record id="setu_inventory_adjustment_report_search_view" model="ir.ui.view">
            <field name="name">setu.inventory.adjustment.report.search.view</field>
            <field name="model">setu.inventory.adjustment.report</field>
            <field name="arch" type="xml">
                <search string="Inventory Adjustment Report">
                    <field name="user_id" string="Name"
                           filter_domain="['|','|','|',('user_id','ilike',self),
                           ('product_id','ilike',self),('location_id','ilike',self),('warehouse_id','ilike',self),]"/>
                    <field name="product_id"/>
                    <field name="count_id"/>
                    <field name="location_id"/>
                    <field name="warehouse_id"/>
                    <filter string="Adjustment IN" name="filter_adjustment_in" domain="[('adjustment_type','=','IN')]"
                            context="{}"/>
                    <filter string="Adjustment OUT" name="filter_adjustment_out"
                            domain="[('adjustment_type','=','OUT')]"
                            context="{}"/>
                    <filter string="Overstock" name="overstock" domain="[('is_overstock','=',True)]"/>
                    <filter string="Understock" name="understock" domain="[('is_understock','=',True)]"/>
                    <separator/>
                    <group>
                        <filter string="Inventory Count" name="group_by_count_id" domain="[]"
                                context="{'group_by':'count_id'}"/>
                        <filter string="Responsible" name="group_by_user_id" domain="[]"
                                context="{'group_by':'user_id'}"/>
                        <filter string="Adjustment Type" name="group_by_adjustment_type" domain="[]"
                                context="{'group_by':'adjustment_type'}"/>
                        <filter string="Warehouse" name="group_by_warehouse" domain="[]"
                                context="{'group_by':'warehouse_id'}"/>
                        <filter string="Location" name="group_by_location" domain="[]"
                                context="{'group_by':'location_id'}"/>
                        <filter string="Product" name="group_by_product" domain="[]"
                                context="{'group_by':'product_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="setu_inventory_adjustment_report_act_server" model="ir.actions.server">
            <field name="name">Inventory Adjustment Report</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_adjustment_report"/>
            <field name="state">code</field>
            <field name="code">action = model.generate_report()</field>
        </record>

        <menuitem id="inventory_adjustment_report_menu" name="Adjustment Report"
                  parent="setu_inventory_count_management.setu_inventory_reporting_menu"
                  action="setu_inventory_count_management.setu_inventory_adjustment_report_action"
                  sequence="3"/>
    </data>
</odoo>

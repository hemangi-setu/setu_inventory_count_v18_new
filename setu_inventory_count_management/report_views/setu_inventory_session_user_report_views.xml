<odoo>
    <!-- Tree View -->
    <record id="setu_inventory_session_user_report_tree_view" model="ir.ui.view">
        <field name="name">setu.inventory.session.user.report.tree</field>
        <field name="model">setu.inventory.session.user.report</field>
        <field name="arch" type="xml">
            <list string="User-wise Inventory Count Report">
                <field name="user_id"/>
                <field name="company_id"/>
                <field name="total_sessions"/>
                <field name="scanned_products"/>
                <field name="accurate_products"/>
                <field name="discrepancy_products"/>
                <field name="accuracy_ratio" widget="percentpie"/>
                <field name="discrepancy_ratio" widget="percentpie"/>
                <field name="avg_time_per_session" widget="float_time"/>
            </list>
        </field>
    </record>

    <record id="setu_inventory_session_user_report_pivot_view" model="ir.ui.view">
        <field name="name">setu.inventory.session.user.report.pivot.view</field>
        <field name="model">setu.inventory.session.user.report</field>
        <field name="arch" type="xml">
            <pivot string="User-wise Inventory Count Report">
                <field name="user_id" type="row"/>
                <field name="company_id" type="col"/>
                <field name="total_sessions" type="measure"/>
                <field name="scanned_products" type="measure"/>
            </pivot>
        </field>
    </record>
    <record id="setu_inventory_session_user_report_search_view" model="ir.ui.view">
        <field name="name">setu.inventory.session.user.report.search</field>
        <field name="model">setu.inventory.session.user.report</field>
        <field name="arch" type="xml">
            <search string="User-wise Inventory Count Report">
                <field name="user_id"/>
                <field name="company_id"/>
                <group>
                    <filter string="User" name="group_user" context="{'group_by':'user_id'}"/>
                    <filter string="Company" name="group_company" context="{'group_by':'company_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="setu_inventory_session_user_report_action" model="ir.actions.act_window">
        <field name="name">User Statistics Report</field>
        <field name="res_model">setu.inventory.session.user.report</field>
        <field name="view_mode">list,pivot</field>
        <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
    </record>

    <menuitem id="menu_setu_inventory_count_user_report"
              name="User Statistics Report"
              parent="setu_inventory_count_management.setu_inventory_reporting_menu"
              action="setu_inventory_session_user_report_action"
              sequence="6"/>
</odoo>

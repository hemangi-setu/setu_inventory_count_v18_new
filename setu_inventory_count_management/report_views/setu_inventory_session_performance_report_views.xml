<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="view_inventory_session_performance_tree" model="ir.ui.view">
            <field name="name">setu.inventory.session.performance.report.tree</field>
            <field name="model">setu.inventory.session.performance.report</field>
            <field name="arch" type="xml">
                <list string="Session Performance Report">
                    <field name="session_id"/>
                    <field name="count_id"/>
                    <field name="session_start"/>
                    <field name="session_end"/>
                    <field name="duration" widget="float_time"/>
                    <field name="total_products_assigned"/>
                    <field name="total_products_counted"/>
                    <field name="users_involved"/>
                    <field name="avg_time_per_product" widget="float_time"/>
                    <field name="accuracy_ratio" widget="percentpie"/>
                </list>
            </field>
        </record>
        <record id="view_inventory_session_performance_search" model="ir.ui.view">
            <field name="name">setu.inventory.session.performance.report.search</field>
            <field name="model">setu.inventory.session.performance.report</field>
            <field name="arch" type="xml">
                <search string="Session Performance Report">
                    <field name="session_id" string="Session"/>
                    <field name="count_id" string="Inventory Count"/>
                    <group>
                        <filter name="group_by_session" string="Session" context="{'group_by':'session_id'}"/>
                        <filter name="group_by_count" string="Inventory Count" context="{'group_by':'count_id'}"/>
                        <filter name="group_by_user" string="Users Involved" context="{'group_by':'users_involved'}"/>
                    </group>
                </search>
            </field>
        </record>


        <record id="view_inventory_session_performance_pivot" model="ir.ui.view">
            <field name="name">setu.inventory.session.performance.report.pivot</field>
            <field name="model">setu.inventory.session.performance.report</field>
            <field name="arch" type="xml">
                <pivot string="Session Performance Report">
                    <field name="count_id" type="row"/>
                    <field name="session_id" type="row"/>
                    <field name="users_involved" type="measure"/>
                    <field name="duration" type="measure"/>
                    <field name="avg_time_per_product" type="measure"/>
                    <field name="accuracy_ratio" type="measure"/>
                </pivot>
            </field>
        </record>

        <!-- Action -->
        <record id="action_inventory_session_performance_report" model="ir.actions.act_window">
            <field name="name">Session Performance Report</field>
            <field name="res_model">setu.inventory.session.performance.report</field>
            <field name="view_mode">list,pivot</field>
            <field name="domain">[('company_id', 'in', allowed_company_ids)]</field>
        </record>

        <!-- Menu -->
        <menuitem id="menu_inventory_session_performance_report"
                  name="Session Performance Report"
                  parent="setu_inventory_count_management.setu_inventory_reporting_menu"
                  action="action_inventory_session_performance_report"
                  sequence="20"/>
    </data>
</odoo>

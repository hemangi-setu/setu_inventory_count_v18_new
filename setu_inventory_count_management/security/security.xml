<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="categ_setu_inventory_count" model="ir.module.category">
            <field name="name">Inventory Count</field>
        </record>

        <record id="group_setu_inventory_count_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="setu_inventory_count_management.categ_setu_inventory_count"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
        </record>

        <record id="group_setu_inventory_count_approver" model="res.groups">
            <field name="name">Approver</field>
            <field name="category_id" ref="setu_inventory_count_management.categ_setu_inventory_count"/>
            <field name="implied_ids"
                   eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_user'))]"/>
        </record>

        <record id="group_setu_inventory_count_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="setu_inventory_count_management.categ_setu_inventory_count"/>
            <field name="users" eval="[(4, ref('base.user_root')),(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
    </data>

    <record id="ir_rule_stock_inventory_count" model="ir.rule">
        <field name="name">Inventory Count multi-company</field>
        <field name="model_id" ref="model_setu_stock_inventory_count"/>
        <field name="domain_force">[('warehouse_id.company_id', 'in', company_ids)]</field>
    </record>

    <record id="ir_rule_setu_stock_inventory_count_planner_multi_company" model="ir.rule">
        <field name="name">Inventory Count Planner multi-company</field>
        <field name="model_id" ref="model_setu_stock_inventory_count_planner"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>


    <record id="ir_rule_user_wise_inventory_count_session_MultiCompany" model="ir.rule">
        <field name="name">Inventory Count Session Multi Company</field>
        <field name="active">True</field>
        <field name="model_id" ref="model_setu_inventory_count_session"/>
        <field name="domain_force">[('warehouse_id.company_id', 'in', company_ids + [False])]</field>
    </record>

    <record id="ir_rule_setu_stock_inventory_MultiCompany" model="ir.rule">
        <field name="name">Setu Stock Inventory Multi Company</field>
        <field name="active">True</field>
        <field name="model_id" ref="model_setu_stock_inventory"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>


    <record id="ir_rule_user_wise_inventory_count_session" model="ir.rule">
        <field name="name">Inventory Count Session User</field>
        <field name="active">True</field>
        <field name="model_id" ref="model_setu_inventory_count_session"/>
        <field name="groups" eval="[(4, ref('group_setu_inventory_count_user'))]"/>
        <field name="perm_read" eval="True"/>
        <field name="perm_write" eval="True"/>
        <field name="perm_create" eval="True"/>
        <field name="perm_unlink" eval="False"/>
        <field name="domain_force">[('user_ids','=',user.id)]</field>
    </record>
    <record id="ir_rule_user_wise_inventory_count_session_manager" model="ir.rule">
        <field name="name">Inventory Count Session Manager</field>
        <field name="active">True</field>
        <field name="model_id" ref="model_setu_inventory_count_session"/>
        <field name="groups" eval="[(4, ref('group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1,'=',1)]</field>
    </record>

    <!-- Approver: only counts where they are approver, or no approver set yet -->
    <record id="ir_rule_setu_stock_inventory_count_approver_scope" model="ir.rule">
        <field name="name">Inventory Count: approver scope</field>
        <field name="model_id" ref="model_setu_stock_inventory_count"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">['|', ('approver_id', '=', False), ('approver_id', '=', user.id)]</field>
    </record>
    <record id="ir_rule_setu_stock_inventory_count_manager_scope" model="ir.rule">
        <field name="name">Inventory Count: manager full access</field>
        <field name="model_id" ref="model_setu_stock_inventory_count"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ir_rule_setu_stock_inventory_count_line_approver_scope" model="ir.rule">
        <field name="name">Inventory Count Line: approver scope</field>
        <field name="model_id" ref="model_setu_stock_inventory_count_line"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">['|', ('inventory_count_id.approver_id', '=', False),
            ('inventory_count_id.approver_id', '=', user.id)]
        </field>
    </record>
    <record id="ir_rule_setu_stock_inventory_count_line_manager_scope" model="ir.rule">
        <field name="name">Inventory Count Line: manager full access</field>
        <field name="model_id" ref="model_setu_stock_inventory_count_line"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ir_rule_setu_inventory_count_session_approver_scope" model="ir.rule">
        <field name="name">Inventory Count Session: approver scope</field>
        <field name="model_id" ref="model_setu_inventory_count_session"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">['|', ('approver_id', '=', False), ('approver_id', '=', user.id)]</field>
    </record>

    <record id="ir_rule_setu_inventory_count_session_line_approver_scope" model="ir.rule">
        <field name="name">Inventory Count Session Line: approver scope</field>
        <field name="model_id" ref="model_setu_inventory_count_session_line"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">['|', ('inventory_count_id.approver_id', '=', False),
            ('inventory_count_id.approver_id', '=', user.id)]
        </field>
    </record>
    <record id="ir_rule_setu_inventory_count_session_line_manager_scope" model="ir.rule">
        <field name="name">Inventory Count Session Line: manager full access</field>
        <field name="model_id" ref="model_setu_inventory_count_session_line"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ir_rule_setu_inventory_session_details_approver_scope" model="ir.rule">
        <field name="name">Inventory Session Details: approver scope</field>
        <field name="model_id" ref="model_setu_inventory_session_details"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">['|', ('session_id.approver_id', '=', False), ('session_id.approver_id', '=',
            user.id)]
        </field>
    </record>
    <record id="ir_rule_setu_inventory_session_details_manager_scope" model="ir.rule">
        <field name="name">Inventory Session Details: manager full access</field>
        <field name="model_id" ref="model_setu_inventory_session_details"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ir_rule_setu_stock_inventory_approver_scope" model="ir.rule">
        <field name="name">Setu Stock Inventory (adjustment): approver scope</field>
        <field name="model_id" ref="model_setu_stock_inventory"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
    <record id="ir_rule_setu_stock_inventory_manager_scope" model="ir.rule">
        <field name="name">Setu Stock Inventory (adjustment): manager full access</field>
        <field name="model_id" ref="model_setu_stock_inventory"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ir_rule_setu_stock_inventory_line_approver_scope" model="ir.rule">
        <field name="name">Setu Stock Inventory Line: approver scope</field>
        <field name="model_id" ref="model_setu_stock_inventory_line"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
    <record id="ir_rule_setu_stock_inventory_line_manager_scope" model="ir.rule">
        <field name="name">Setu Stock Inventory Line: manager full access</field>
        <field name="model_id" ref="model_setu_stock_inventory_line"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ir_rule_setu_unscanned_product_lines_approver_scope" model="ir.rule">
        <field name="name">Unscanned Product Lines: approver scope</field>
        <field name="model_id" ref="model_setu_unscanned_product_lines"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">['|', ('inventory_count_id.approver_id', '=', False),
            ('inventory_count_id.approver_id', '=', user.id)]
        </field>
    </record>
    <record id="ir_rule_setu_unscanned_product_lines_manager_scope" model="ir.rule">
        <field name="name">Unscanned Product Lines: manager full access</field>
        <field name="model_id" ref="model_setu_unscanned_product_lines"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>

    <record id="ir_rule_setu_stock_inventory_count_planner_approver_scope" model="ir.rule">
        <field name="name">Inventory Count Planner: approver scope</field>
        <field name="model_id" ref="model_setu_stock_inventory_count_planner"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">['|', ('approver_id', '=', False), ('approver_id', '=', user.id)]</field>
    </record>
    <record id="ir_rule_setu_stock_inventory_count_planner_manager_scope" model="ir.rule">
        <field name="name">Inventory Count Planner: manager full access</field>
        <field name="model_id" ref="model_setu_stock_inventory_count_planner"/>
        <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
    <record id="product_discrepancy_company_rule" model="ir.rule">
        <field name="name">Discrepancy Report Company Access</field>
        <field name="model_id"
               ref="model_setu_product_wise_discrepancy_report"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids + [False])]
        </field>
    </record>
    <record id="product_discrepancy_approver_rule" model="ir.rule">
        <field name="name">Approver Own Discrepancy Data</field>
        <field name="model_id"
               ref="model_setu_product_wise_discrepancy_report"/>
        <field name="groups"
               eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">
            [('approver_id', '=', user.id)]
        </field>
    </record>
    <record id="product_discrepancy_manager_rule" model="ir.rule">
        <field name="name">Manager Discrepancy Data</field>
        <field name="model_id"
               ref="model_setu_product_wise_discrepancy_report"/>
        <field name="groups"
               eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">
            [(1, '=', 1)]
        </field>
    </record>

    <record id="session_user_report_company_rule" model="ir.rule">
        <field name="name">User Statistics Report: company</field>
        <field name="model_id" ref="model_setu_inventory_session_user_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
    </record>
    <record id="session_user_report_approver_rule" model="ir.rule">
        <field name="name">User Statistics Report: approver own counts</field>
        <field name="model_id" ref="model_setu_inventory_session_user_report"/>
        <field name="groups"
               eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        <field name="domain_force">[('approver_id', '=', user.id)]</field>
    </record>
    <record id="session_user_report_manager_rule" model="ir.rule">
        <field name="name">User Statistics Report: manager full</field>
        <field name="model_id" ref="model_setu_inventory_session_user_report"/>
        <field name="groups"
               eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
    </record>
</odoo>

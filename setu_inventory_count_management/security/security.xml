<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="categ_setu_inventory_count" model="ir.module.category">
            <field name="name">Inventory Count</field>
        </record>

        <record id="group_setu_inventory_count_user" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="setu_inventory_count_management.categ_setu_inventory_count"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
        </record>

        <record id="group_setu_inventory_count_approver" model="res.groups">
            <field name="name">Approver</field>
            <field name="category_id" ref="setu_inventory_count_management.categ_setu_inventory_count"/>
            <field name="implied_ids"
                   eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_user'))]"/>
        </record>

        <record id="group_setu_inventory_count_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="setu_inventory_count_management.categ_setu_inventory_count"/>
            <field name="users" eval="[(4, ref('base.user_root')),(4, ref('base.user_admin'))]"/>
            <field name="implied_ids"
                   eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
    </data>

    <data>
        <!-- Active company (ir.rule eval context: company_id) -->
        <record id="setu_rule_company_inventory_count" model="ir.rule">
            <field name="name">Inventory Count: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory_count"/>
             <field name="domain_force">[('warehouse_id.company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_count_session" model="ir.rule">
            <field name="name">Inventory Count Session: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_count_session"/>
            <field name="domain_force">[('warehouse_id.company_id', 'in', company_ids + [False])]</field>
        </record>
        <record id="setu_rule_company_planner" model="ir.rule">
            <field name="name">Inventory Count Planner: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory_count_planner"/>
            <field name="domain_force">[('company_id', 'in', company_ids + [False])]</field>
        </record>
        <record id="setu_rule_company_stock_inventory" model="ir.rule">
            <field name="name">Setu Stock Inventory (adjustment): active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_session_details" model="ir.rule">
            <field name="name">Inventory Session Details: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_details"/>
            <field name="domain_force">['|', ('session_id.company_id', '=', False), ('session_id.company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_unscanned_lines" model="ir.rule">
            <field name="name">Unscanned Product Lines: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_unscanned_product_lines"/>
            <field name="domain_force">['|', '|', '|', ('inventory_count_id.company_id', '=', False), ('inventory_count_id.company_id', 'in', company_ids), ('session_id.company_id', '=', False), ('session_id.company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_discrepancy_report" model="ir.rule">
            <field name="name">Inventory Discrepancy Report: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_discrepancy_report"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_session_user_report" model="ir.rule">
            <field name="name">Session User Report: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_user_report"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_count_wise_disc" model="ir.rule">
            <field name="name">Count-wise Discrepancy Report: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_count_wise_discrepancy_report"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_product_wise_disc" model="ir.rule">
            <field name="name">Product-wise Discrepancy Report: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_product_wise_discrepancy_report"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_location_wise_disc" model="ir.rule">
            <field name="name">Location-wise Discrepancy Report: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_location_wise_discrepancy_report"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>
        <record id="setu_rule_company_session_perf_report" model="ir.rule">
            <field name="name">Session Performance Report: active company</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_performance_report"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

        <!-- Manager: full row access -->
        <record id="setu_rule_manager_all_inventory_count" model="ir.rule">
            <field name="name">Inventory Count: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory_count"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_count_session" model="ir.rule">
            <field name="name">Inventory Count Session: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_count_session"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_planner" model="ir.rule">
            <field name="name">Inventory Count Planner: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory_count_planner"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_stock_inventory" model="ir.rule">
            <field name="name">Setu Stock Inventory: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_session_details" model="ir.rule">
            <field name="name">Inventory Session Details: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_details"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_unscanned_lines" model="ir.rule">
            <field name="name">Unscanned Product Lines: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_unscanned_product_lines"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_discrepancy_report" model="ir.rule">
            <field name="name">Inventory Discrepancy Report: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_discrepancy_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_session_user_report" model="ir.rule">
            <field name="name">Session User Report: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_user_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_count_wise_disc" model="ir.rule">
            <field name="name">Count-wise Discrepancy Report: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_count_wise_discrepancy_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_product_wise_disc" model="ir.rule">
            <field name="name">Product-wise Discrepancy Report: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_product_wise_discrepancy_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_location_wise_disc" model="ir.rule">
            <field name="name">Location-wise Discrepancy Report: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_location_wise_discrepancy_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>
        <record id="setu_rule_manager_all_session_perf" model="ir.rule">
            <field name="name">Session Performance Report: manager full access</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_performance_report"/>
            <field name="domain_force">[(1, '=', 1)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_manager'))]"/>
        </record>

        <!-- Approver: rows where user is approver on the related inventory count (or planner) -->
        <record id="setu_rule_approver_inventory_count" model="ir.rule">
            <field name="name">Inventory Count: approver sees assigned counts</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory_count"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_count_session" model="ir.rule">
            <field name="name">Inventory Count Session: approver sees sessions of assigned counts</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_count_session"/>
            <field name="domain_force">[('inventory_count_id.approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_planner" model="ir.rule">
            <field name="name">Inventory Count Planner: approver sees assigned planners</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory_count_planner"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_stock_inventory" model="ir.rule">
            <field name="name">Setu Stock Inventory: approver sees assigned adjustments</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_stock_inventory"/>
            <field name="domain_force">[('inventory_count_id.approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_session_details" model="ir.rule">
            <field name="name">Inventory Session Details: approver sees details for assigned counts</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_details"/>
            <field name="domain_force">[('session_id.inventory_count_id.approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_unscanned_lines" model="ir.rule">
            <field name="name">Unscanned Product Lines: approver sees lines for assigned counts</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_unscanned_product_lines"/>
            <field name="domain_force">['|', ('inventory_count_id.approver_id', '=', user.id), ('session_id.inventory_count_id.approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_discrepancy_report" model="ir.rule">
            <field name="name">Inventory Discrepancy Report: approver sees assigned rows</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_discrepancy_report"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_session_user_report" model="ir.rule">
            <field name="name">Session User Report: approver sees assigned rows</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_user_report"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_count_wise_disc" model="ir.rule">
            <field name="name">Count-wise Discrepancy Report: approver sees assigned rows</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_count_wise_discrepancy_report"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_product_wise_disc" model="ir.rule">
            <field name="name">Product-wise Discrepancy Report: approver sees assigned rows</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_product_wise_discrepancy_report"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_location_wise_disc" model="ir.rule">
            <field name="name">Location-wise Discrepancy Report: approver sees assigned rows</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_location_wise_discrepancy_report"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>
        <record id="setu_rule_approver_session_perf" model="ir.rule">
            <field name="name">Session Performance Report: approver sees assigned rows</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_session_performance_report"/>
            <field name="domain_force">[('approver_id', '=', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_approver'))]"/>
        </record>

        <!-- User (counter): own sessions and related operational data only; no reports or planners -->
        <record id="setu_rule_user_count_session" model="ir.rule">
            <field name="name">Inventory Count Session: user sees own sessions</field>
            <field name="model_id" ref="setu_inventory_count_management.model_setu_inventory_count_session"/>
            <field name="domain_force">[('user_ids', 'in', user.id)]</field>
            <field name="groups" eval="[(4, ref('setu_inventory_count_management.group_setu_inventory_count_user'))]"/>
        </record>
    </data>

</odoo>

<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="setu_unscanned_product_action_wizard_form_view" model="ir.ui.view">
            <field name="name">setu.unscanned.product.action.wizard.form.view</field>
            <field name="model">setu.unscanned.product.action.wizard</field>
            <field name="arch" type="xml">
                <form string="Select Action">
                    <strong>Select Action For Unscanned Products
                    </strong>
                    <br/>
                    <br/>
                    <field name="unscanned_product_line_ids" invisible="1"/>
                    <group>
                        <group>
                            <field name="action" required="1"/>
                        </group>
                    </group>
                    <footer>
                        <button name="set_action" string="Set Action" type="object" class="oe_highlight"/>

                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="setu_unscanned_product_action_wizard_action" model="ir.actions.act_window">
            <field name="name">Select Action For Unscanned Products</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">setu.unscanned.product.action.wizard</field>
            <field name="binding_view_types">form</field>
            <field name="view_mode">form</field>
            <field name="view_id" ref="setu_unscanned_product_action_wizard_form_view"/>
            <field name="target">new</field>
        </record>
    </data>
</odoo>

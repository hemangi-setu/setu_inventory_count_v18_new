<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <record id="setu_inventory_session_creator_form_view" model="ir.ui.view">
            <field name="name">setu.inventory.session.creator.form.view</field>
            <field name="model">setu.inventory.session.creator</field>
            <field name="arch" type="xml">
                <form string="Session Creator">
                    <sheet>
                        <group>
                            <group>
                                <field name="user_ids" widget="many2many_tags"
                                       options="{'no_create': True, 'no_create_edit':True}"/>
                                <field name="session_strategy" invisible="1"/>
                                <field name="product_load_type" invisible="1"/>
                                <field name="location_ids" widget="many2many_tags"
                                       required="session_strategy == 'location_wise'"
                                       invisible="session_strategy != 'location_wise'"
                                       options="{'no_create': True, 'no_create_edit':True}"
                                       domain="[('usage','=','internal'),('company_id','=',company_id),('warehouse_id','=',warehouse_id)]"/>
                                <field name="assignment_basis" widget="radio"
                                       invisible="session_strategy != 'product_wise' or product_load_type != 'user_assignment_products'"/>
                                <field name="product_ids" widget="many2many_tags"
                                       invisible="session_strategy != 'product_wise' or product_load_type != 'user_assignment_products' or assignment_basis != 'product'"
                                       options="{'no_create': True, 'no_create_edit':True}"/>
                                <field name="category_ids" widget="many2many_tags"
                                       invisible="session_strategy != 'product_wise' or product_load_type != 'user_assignment_products' or assignment_basis != 'category'"
                                       options="{'no_create': True, 'no_create_edit':True}"/>
                                <field name="is_multi_session" invisible="1"/>
                                <field name="parent_count_id" invisible="1"/>
                                <field name="company_id" invisible="1"/>
                                <field name="warehouse_id" invisible="1"/>
                            </group>
                        </group>
                    </sheet>
                    <footer>
                        <button name="confirm" class="oe_highlight"
                                type="object" string="Confirm"/>
                        <button string="Cancel" class="oe_link" special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

    </data>
</odoo>
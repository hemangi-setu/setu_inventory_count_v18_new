<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="setu_inventory_count_session_line_list_view" model="ir.ui.view">
            <field name="name">setu.inventory.count.session.line.list</field>
            <field name="model">setu.inventory.count.session.line</field>
            <field name="arch" type="xml">
                <list string="Session Lines" create="0"
                      decoration-danger="state == 'Reject'"
                      decoration-primary="state == 'Pending Review'"
                      default_order="date_of_scanning desc">
                    <field name="session_id"/>
                    <field name="inventory_count_id"/>
                    <field name="date_of_scanning"/>
                    <field name="product_id"/>
                    <field name="location_id"/>
                    <field name="lot_id" optional="hide"/>
                    <field name="serial_number_ids" widget="many2many_tags" optional="hide"/>
                    <field name="theoretical_qty" optional="show"/>
                    <field name="scanned_qty" string="Counted Qty"/>
                    <field name="difference_qty" optional="show"/>
                    <field name="state"/>
                    <field name="user_ids" widget="many2many_tags" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="setu_inventory_count_session_line_form_view" model="ir.ui.view">
            <field name="name">setu.inventory.count.session.line.form</field>
            <field name="model">setu.inventory.count.session.line</field>
            <field name="arch" type="xml">
                <form string="Session Line" create="0">
                    <sheet>
                        <group>
                            <group>
                                <field name="session_id" readonly="1"/>
                                <field name="inventory_count_id" readonly="1"/>
                                <field name="product_id" readonly="1"/>
                                <field name="location_id" readonly="1"/>
                                <field name="tracking" readonly="1"/>
                            </group>
                            <group>
                                <field name="lot_id" readonly="1" invisible="tracking != 'lot'"/>
                                <field name="serial_number_ids" widget="many2many_tags" readonly="1"
                                       invisible="tracking != 'serial'"/>
                                <field name="not_found_serial_number_ids" widget="many2many_tags" readonly="1"
                                       invisible="tracking != 'serial'"/>
                                <field name="theoretical_qty" readonly="1"/>
                                <field name="scanned_qty" readonly="1"/>
                                <field name="difference_qty" readonly="1"/>
                                <field name="state" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="setu_inventory_count_session_line_search_view" model="ir.ui.view">
            <field name="name">setu.inventory.count.session.line.search</field>
            <field name="model">setu.inventory.count.session.line</field>
            <field name="arch" type="xml">
                <search string="Session Lines">
                    <field name="session_id"/>
                    <field name="inventory_count_id"/>
                    <field name="product_id"/>
                    <field name="location_id"/>
                    <field name="state"/>
                    <filter string="Pending Review" name="pending_review" domain="[('state', '=', 'Pending Review')]"/>
                    <filter string="Approved" name="approved" domain="[('state', '=', 'Approve')]"/>
                    <filter string="Rejected" name="rejected" domain="[('state', '=', 'Reject')]"/>
                    <group>
                        <filter string="Session" name="group_by_session" context="{'group_by': 'session_id'}"/>
                        <filter string="Count" name="group_by_count" context="{'group_by': 'inventory_count_id'}"/>
                        <filter string="Product" name="group_by_product" context="{'group_by': 'product_id'}"/>
                        <filter string="Location" name="group_by_location" context="{'group_by': 'location_id'}"/>
                        <filter string="State" name="group_by_state" context="{'group_by': 'state'}"/>
                        <filter string="Date" name="group_by_date" context="{'group_by': 'date_of_scanning:day'}"/>
                    </group>
                </search>
            </field>
        </record>
    </data>
</odoo>

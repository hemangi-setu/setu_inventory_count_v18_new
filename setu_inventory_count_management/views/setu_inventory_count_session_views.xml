<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="inventory_count_session_form_view" model="ir.ui.view">
            <field name="name">.inventory_count_session.form</field>
            <field name="model">setu.inventory.count.session</field>
            <field name="arch" type="xml">
                <form string="Inventory Count Session" create="0">
                    <div class="alert alert-info" role="alert"
                         invisible="not current_scanning_location_id">
                        <strong>Currently scanned Details :</strong>
                        <div invisible="not current_scanning_location_id">
                            <strong>Location :</strong>
                            <strong>
                                <field name="current_scanning_location_id" readonly="1" force_save="1"/>
                            </strong>
                        </div>
                        <div invisible="not current_scanning_lot_id">
                            <strong>Lot/Serial Number :</strong>
                            <strong>
                                <field name="current_scanning_lot_id" readonly="1" force_save="1"/>
                            </strong>
                        </div>
                        <div invisible="not current_scanning_product_id">
                            <strong>Product :</strong>
                            <strong>
                                <field name="current_scanning_product_id" readonly="1" force_save="1"/>
                            </strong>
                        </div>
                    </div>
                    <header>
                        <field name="state" widget="statusbar" statusbar_visible="Draft,In Progress,Done"/>
                        <field name="count_state" invisible="1"/>
                        <field name="is_session_approved" invisible="1"/>
                        <field name="current_state" invisible="1"/>
                        <field name="session_ids" invisible="1"/>
                        <field name="re_open_session_bool" invisible="1"/>
                        <field name="rejected_lines_count" invisible="1"/>
                        <button name="start" type="object" string="Start" class="oe_highlight"
                                invisible="state == 'Cancel' or current_state != 'Created'"/>
                        <button name="pause" type="object" string="Pause" class="oe_highlight"
                                invisible="state == 'Cancel' or current_state in ['Created','Pause','End']"/>
                        <button name="resume" type="object" string="Resume" class="oe_highlight"
                                invisible="state == 'Cancel' or current_state in ['Created','Resume','Start','End']"/>
                        <button name="submit" type="object" string="Submit" class="oe_highlight"
                                invisible="state == 'Cancel' or current_state not in ['Start','Resume']"/>
                        <button name="approve_all_lines" type="object" string="Approve Session Lines"
                                groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                class="oe_highlight"
                                invisible="approval_scope != 'session_level' or state != 'Submitted' or state == 'Done' or not session_line_ids"/>
                        <button name="reject_all_lines" type="object" string="Reject Session Lines"
                                groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                class="oe_highlight"
                                invisible="approval_scope != 'session_level' or state != 'Submitted' or state == 'Done' or not session_line_ids"/>
                        <button name="validate_session" type="object" string="Validate" class="oe_highlight"
                                confirm="Are you sure you want to Validate the Session? "
                                groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                invisible="approval_scope == 'count_level' or state != 'Submitted' or state == 'Done'"/>
                        <button name="check_unscanned_session" type="object" string="Check Unscanned"
                                class="oe_highlight"
                                groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                invisible="adjustment_strategy != 'session_level' or session_strategy == 'product_wise' or state != 'Submitted' or state == 'Done' or unscanned_product_lines_ids"/>
                        <button name="cancel_session" type="object" string="Cancel" class="oe_highlight"
                                groups="setu_inventory_count_management.group_setu_inventory_count_manager"
                                confirm="Are you sure you want to Cancel the Session ? "
                                invisible="state != 'Draft'"/>
                    </header>
                    <sheet>
                        <div class="oe_button_box" name="button_box">
                            <button name="action_view_session_history" type="object" class="oe_stat_button"
                                    icon="fa-clock-o"
                                    invisible="current_state == 'Created'">
                                <field name="time_taken"/>
                            </button>
                            <button name="action_open_session_inventory_adjustments"
                                    type="object"
                                    class="oe_stat_button"
                                    icon="fa-exchange"
                                    groups="setu_inventory_count_management.group_setu_inventory_count_approver"
                                    invisible="session_adjustment_count == 0">
                                <field name="session_adjustment_count" widget="statinfo" string="Adjustments"/>
                            </button>
                            <field name="count_child_session_ids" invisible="1"/>
                            <button name="action_open_child_sessions" type="object" class="oe_stat_button"
                                    icon="fa-pencil-square-o"
                                    invisible="count_child_session_ids == 0">
                                <field name="count_child_session_ids" widget="statinfo" string="Re-Session"/>
                            </button>
                            <button name="action_open_unscanned_products" type="object" string="Unscanned Products"
                                    groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                    class="oe_stat_button"
                                    icon="fa-exchange"
                                    invisible="not unscanned_product_lines_ids"
                            >
                                <field name="unscanned_product_lines_ids" widget="statinfo" string="Unscanned Products"/>
                            </button>
                            <field name="unscanned_product_lines_ids" invisible="1"/>
                        </div>
                        <div class="oe_title">
                            <div style="margin-bottom: 10px;word-wrap: break-word;border: 1px dotted;padding: 3px;font-weight: bold;color: #666666;background: antiquewhite;"
                                 invisible="not use_barcode_scanner">
                                <p>
                                    <strong>1.</strong>
                                    Scan the location first
                                    <br/>
                                    <strong>2.</strong>
                                    If "No Tracking" type product then directly scan the product's Barcode.
                                    <br/>
                                    &#160;&#160;&#160;&#160;&#160;If "Serial" type product then scan Barcode of the
                                    serial number
                                    <br/>
                                    &#160;&#160;&#160;&#160;&#160;If "Lot" type product then scan Barcode of lot and
                                    then scan product's Barcode, if you want change the lot
                                    <br/>
                                    &#160;&#160;&#160;&#160;&#160;then scan again the Barcode of lot and rest will be
                                    the same.
                                    <br/>
                                    <strong>3.</strong>
                                    Change the location every time if you start to scan the product of different
                                    location.
                                </p>
                            </div>
                            <div>
                                <h1>
                                    <field name="name" nolabel="1" readonly="1"/>
                                </h1>
                            </div>

                        </div>
                        <group>
                            <group string="Session Details">
                                <field name="_barcode_scanned" widget="setu_barcode_handler"/>
                                <field name="inventory_count_id" readonly="1"
                                       groups="setu_inventory_count_management.group_setu_inventory_count_manager"/>
                                <field name="user_ids" widget="many2many_tags"
                                       readonly="state != 'Draft'"/>
                                <field name="session_strategy" readonly="1"/>
                                <field name="is_revision" readonly="1" invisible="1"/>
                                <field name="revision_of_id" readonly="1" invisible="not revision_of_id"/>
                                <field name="session_id" readonly="1" invisible="not session_id"/>
                                <field name="assigned_location_ids" widget="many2many_tags" readonly="1"
                                       invisible="session_strategy == 'product_wise'"
                                       options="{'no_create': True, 'no_open':True}"/>
                                <field name="allowed_scan_location_ids" invisible="1"/>
                                <field name="warehouse_id" readonly="1" options="{'no_create': True, 'no_open':True}"/>
                                <field name="company_id" invisible="1"/>
                                <field name="use_barcode_scanner" widget="boolean_toggle" readonly="1"/>
                                <field name="adjustment_strategy" invisible="1"/>
                            </group>
                            <group string="Progress">
                                <field name="session_start_date" readonly="1" invisible="1"/>
                                <field name="session_end_date" readonly="1" invisible="1"/>
                                <field name="session_submit_date" string="Submit Date" readonly="1"
                                       invisible="not session_submit_date"/>
                                <field name="total_products" readonly="1"/>
                                <field name="total_scanned_products" readonly="1"/>
                                <field name="is_multi_session" invisible="1"/>
                                <field name="to_be_scanned" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Session Lines">
                                <field name="session_line_ids"
                                       force_save="1"
                                       nolabel="1" readonly="current_state not in ['Start', 'Resume']">
                                    <list decoration-muted="state=='Reject'"
                                          decoration-danger="state == 'Reject' or is_system_generated"
                                          delete="true" editable="bottom"
                                          decoration-primary="state=='Pending Review'">
                                        <field name="date_of_scanning" column_invisible="True"/>
                                        <field name="user_ids" widget="many2many_tags" readonly="1"
                                               column_invisible="1"/>
                                        <field name="product_id" required="True" force_save="1"
                                               domain="[('is_storable', '=', True)]"
                                               options="{'no_create': True, 'no_open':True}"
                                               readonly="parent.use_barcode_scanner"/>
                                        <field name="tracking" column_invisible="True"
                                               readonly="parent.use_barcode_scanner"/>

                                        <field name="location_id" force_save="1" required="1"
                                               domain="[('id', 'in', parent.allowed_scan_location_ids), ('usage','=','internal'),('company_id','=',parent.company_id)]"
                                               options="{'no_create': True, 'no_open':True}"
                                               readonly="parent.use_barcode_scanner"/>
                                        <field name="serial_number_ids" widget="many2many_tags" force_save="1"
                                               domain="[('product_id', '=', product_id)]"
                                               options="{'no_create': True, 'no_open':True}"
                                               readonly="tracking != 'serial' or parent.use_barcode_scanner"
                                               required="tracking == 'serial'"/>
                                        <field name="not_found_serial_number_ids" widget="many2many_tags" force_save="1"
                                               readonly="1"/>
                                        <field name="lot_id" force_save="1"
                                               options="{'no_create': True, 'no_open':True}"
                                               domain="[('product_id', '=', product_id)]"
                                               readonly="parent.use_barcode_scanner or tracking != 'lot'"
                                               required="tracking == 'lot'"/>
                                        <field name="is_multi_session" column_invisible="True"/>
                                        <field name="theoretical_qty"
                                               force_save="1"
                                               groups="setu_inventory_count_management.group_setu_inventory_count_approver"
                                               readonly="1"
                                        />
                                        <field name="scanned_qty" string="Counted Qty" force_save="1"
                                               readonly="product_scanned or parent.current_state in ['Created','Pause','End'] or not product_id or not location_id"/>
                                        <field name="difference_qty" readonly="1"
                                               groups="setu_inventory_count_management.group_setu_inventory_count_approver"/>
                                        <field name="state" readonly="1"
                                               column_invisible="parent.approval_scope == 'count_level' or parent.is_multi_session or parent.state not in ['Submitted', 'Done']"
                                               style="text-align:center !important;"/>
                                        <field name="user_calculation_mistake"
                                               groups="setu_inventory_count_management.group_setu_inventory_count_approver"
                                               style="text-align:center !important;" force_save="1"
                                               readonly="1"/>
                                        <field name="product_scanned" string="Scanned?"
                                               style="text-align:center !important;"
                                               readonly="not product_id or parent.current_state in ['Created','Pause','End']"/>
                                        <field name="is_system_generated" column_invisible="True"/>
                                        <button string="Approve"
                                                invisible="parent.state != 'Submitted' or parent.approval_scope == 'count_level'"
                                                style="font-size: 1rem; font-weight: bold;" class="oe_highlight"
                                                groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                                type="object"
                                                name="change_line_state_to_approve"/>
                                        <button string="Reject"
                                                invisible="parent.state != 'Submitted' or parent.approval_scope == 'count_level'"
                                                class="oe_highlight"
                                                style="background-color:red; font-size: 1rem; font-weight: bold;"
                                                groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                                type="object"
                                                name="change_line_state_to_reject"/>
                                        <button string="Add as Counted"
                                                invisible="parent.state != 'Submitted' or not is_system_generated"
                                                class="oe_highlight"
                                                style="background-color:green; font-size: 1rem; font-weight: bold;"
                                                groups="setu_inventory_count_management.group_setu_inventory_count_approver,setu_inventory_count_management.group_setu_inventory_count_manager"
                                                type="object"
                                                name="set_theoretical"/>

                                    </list>
                                    <form create="0" edit="0">
                                        <sheet>
                                            <group>
                                                <group>
                                                    <field name="session_id" readonly="1"/>
                                                    <field name="inventory_count_id" readonly="1"/>
                                                    <field name="inventory_count_line_id" invisible="1"/>
                                                    <field name="location_id" readonly="1"/>
                                                    <field name="is_multi_session" readonly="1"/>
                                                    <field name="date_of_scanning" invisible="1"/>
                                                </group>
                                                <group>
                                                    <field name="product_id" readonly="1"/>
                                                    <field name="tracking" invisible="1"/>
                                                    <field name="theoretical_qty"
                                                           readonly="1"
                                                           groups="setu_inventory_count_management.group_setu_inventory_count_approver"/>
                                                    <field name="scanned_qty" readonly="1"/>
                                                    <field name="serial_number_ids" widget="many2many_tags"
                                                           invisible="not serial_number_ids"/>
                                                    <field name="not_found_serial_number_ids" widget="many2many_tags"
                                                           readonly="1"/>
                                                    <field name="lot_id" invisible="not lot_id" readonly="1"/>
                                                    <field name="product_scanned" invisible="1"/>
                                                </group>
                                            </group>
                                        </sheet>
                                    </form>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                    <field name="_barcode_scanned" widget="barcode_handler"/>
                </form>
            </field>
        </record>


        <record id="inventory_count_session_tree_view" model="ir.ui.view">
            <field name="name">.inventory_count_session.tree</field>
            <field name="model">setu.inventory.count.session</field>
            <field name="arch" type="xml">
                <list string="Inventory Count Session"
                      decoration-danger="color==1"
                      decoration-muted="state=='Cancel'"
                      create="0"
                      default_order="id desc">
                    <field name="name"/>
                    <field name="color" column_invisible="True"/>
                    <field name="user_ids" widget="many2many_tags"/>
                    <field name="assigned_location_ids" widget="many2many_tags"/>
                    <field name="warehouse_id"/>
                    <field name="session_start_date"/>
                    <field name="session_submit_date"/>
                    <field name="total_products"/>
                    <field name="total_scanned_products"/>
                    <field name="to_be_scanned"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="setu_inventory_count_session_kanban_view" model="ir.ui.view">
            <field name="name">setu.inventory.count.session.kanban</field>
            <field name="model">setu.inventory.count.session</field>
            <field name="arch" type="xml">
                <kanban default_group_by="state" create="false" edit="false" delete="false">
                    <field name="state" readonly="1"/>
                    <field name="id"/>
                    <field name="color"/>
                    <field name="name" readonly="1"/>
                    <field name="warehouse_id" readonly="1"/>
                    <field name="user_ids" widget="many2many_tags" readonly="1"/>
                    <field name="to_be_scanned" readonly="1"/>
                    <field name="total_products" readonly="1"/>
                    <field name="total_scanned_products"/>
                    <field name="user_ids_count"/>
                    <field name="kanban_user_names" readonly="1"/>
                    <field name="kanban_location_names" readonly="1"/>
                    <field name="create_uid" invisible="1" readonly="1"/>
                    <field name="create_date" invisible="1" readonly="1"/>
                    <field name="current_scanning_location_id" invisible="1" readonly="1"/>
                    <field name="current_state" invisible="1" readonly="1"/>
                    <field name="inventory_count_id" invisible="1" readonly="1"/>
                    <field name="is_multi_session" invisible="1" readonly="1"/>
                    <field name="is_revision" invisible="1" readonly="1"/>
                    <field name="revision_of_id" invisible="1" readonly="1"/>
                    <field name="is_session_approved" invisible="1" readonly="1"/>
                    <field name="approval_scope" invisible="1" readonly="1"/>
                    <field name="rejected_lines_count" readonly="1"/>
                    <field name="write_uid" invisible="1" readonly="1"/>
                    <field name="write_date" invisible="1" readonly="1"/>
                    <field name="location_id" invisible="1" readonly="1"/>
                    <field name="assigned_location_ids" invisible="1" readonly="1"/>
                    <field name="access_token" invisible="1" readonly="1"/>
                    <field name="session_ids" invisible="1" readonly="1"/>
                    <field name="session_end_date" invisible="1" readonly="1"/>
                    <field name="session_start_date" invisible="1" readonly="1"/>
                    <field name="session_submit_date" invisible="1" readonly="1"/>
                    <field name="time_taken" readonly="1"/>
                    <templates>
                        <t t-name="card">
                            <t t-set="progress_percent"
                               t-value="(record.total_products.value &amp;&amp; record.total_scanned_products.value >= 0) ? (record.total_scanned_products.value * 100.0 / record.total_products.value) : 0.0"/>
                            <t t-set="safe_progress"
                               t-value="(progress_percent === progress_percent) ? progress_percent : 0"/>
                            <t t-set="effective_progress"
                               t-value="record.state.raw_value === 'Done' ? 100 : safe_progress"/>
                            <div class="oe_kanban_global_click o_kanban_record shadow-sm rounded-3 p-3"
                                 t-att-style="'--card-color:' + ({'Draft':'#6b7280','In Progress':'#2563eb','Submitted':'#f59e0b','Done':'#16a34a','Cancel':'#dc2626'}[record.state.raw_value] || '#6b7280') + '; border:1px solid #e5e7eb; border-left:0; background: linear-gradient(360deg, var(--card-color), transparent 98%) left top / 5px 100% no-repeat, #ffffff;'">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <div class="fw-bold fs-6 mb-1">
                                            <field name="name"/>
                                        </div>
                                        <div class="text-muted small">
                                            <i class="fa fa-building-o me-1"/>
                                            <field name="warehouse_id"/>
                                        </div>
                                    </div>
                                    <div>
                                        <span class="badge rounded-pill text-bg-secondary" invisible="state != 'Draft'">
                                            Draft
                                        </span>
                                        <span class="badge rounded-pill text-bg-primary"
                                              invisible="state != 'In Progress'">In Progress
                                        </span>
                                        <span class="badge rounded-pill text-bg-warning"
                                              invisible="state != 'Submitted'">Submitted
                                        </span>
                                        <span class="badge rounded-pill text-bg-success" invisible="state != 'Done'">
                                            Done
                                        </span>
                                        <span class="badge rounded-pill text-bg-danger" invisible="state != 'Cancel'">
                                            Cancelled
                                        </span>
                                    </div>
                                </div>

                                <div class="small fw-semibold mb-2 text-info" invisible="not is_revision">
                                    <i class="fa fa-code-fork me-1"/>
                                    Re-Session (Revision)
                                </div>
                                <div class="small fw-semibold mb-2 text-info" invisible="is_revision or not session_id">
                                    <i class="fa fa-code-fork me-1"/>
                                    Re-Session
                                </div>

                                <div class="mb-3 small text-muted">
                                    <div class="d-flex align-items-center gap-1 text-nowrap" style="overflow:hidden;">
                                        <i class="fa fa-user"/>
                                        <span style="overflow:hidden; text-overflow:ellipsis;">
                                            <t t-esc="record.kanban_user_names.value || '-'"/>
                                        </span>
                                    </div>
                                    <div class="d-flex align-items-center gap-1 text-nowrap" style="overflow:hidden;"
                                         invisible="not assigned_location_ids">
                                        <i class="fa fa-map-marker"/>
                                        <span style="overflow:hidden; text-overflow:ellipsis;">
                                            <t t-esc="record.kanban_location_names.value || '-'"/>
                                        </span>
                                    </div>
                                    <div class="d-flex align-items-center gap-1 text-nowrap" style="overflow:hidden;"
                                         invisible="assigned_location_ids">
                                        <i class="fa fa-map-marker"/>
                                        <span style="overflow:hidden; text-overflow:ellipsis;">
                                            <t t-esc="record.kanban_location_names.value || '-'"/>
                                        </span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="d-flex justify-content-between align-items-center small fw-semibold mb-1">
                                        <span>Scanning Progress</span>
                                        <span><t t-esc="Math.round(effective_progress)"/>%
                                        </span>
                                    </div>
                                    <div class="progress" style="height: 10px;">
                                        <div class="progress-bar"
                                             role="progressbar"
                                             t-att-class="record.state.raw_value === 'Done' ? 'progress-bar bg-success' : (record.rejected_lines_count.value > 0 ? 'progress-bar bg-danger' : (record.state.raw_value === 'In Progress' ? 'progress-bar bg-primary progress-bar-striped progress-bar-animated' : (record.state.raw_value === 'Submitted' ? 'progress-bar bg-warning' : (record.state.raw_value === 'Cancel' ? 'progress-bar bg-danger' : 'progress-bar bg-secondary'))))"
                                             t-att-style="'width:' + Math.round(effective_progress) + '%;'"></div>
                                    </div>
                                    <div class="small text-muted mt-1">
                                        <field name="total_scanned_products"/>
                                        /
                                        <field name="total_products"/>
                                        Products
                                    </div>
                                </div>

                                <div class="small fw-semibold mb-2 text-warning"
                                     invisible="state not in ['Draft', 'In Progress'] or to_be_scanned == 0">
                                    <i class="fa fa-exclamation-triangle me-1"/>
                                    Pending Scan
                                </div>
                                <div class="small fw-semibold mb-2 text-warning"
                                     invisible="state != 'Submitted' or approval_scope != 'session_level'">
                                    <i class="fa fa-hourglass-half me-1"/>
                                    Waiting Approval
                                </div>
                                <div class="small fw-semibold mb-2 text-danger"
                                     invisible="state != 'Cancel' or not session_ids">
                                    <i class="fa fa-refresh me-1"/>
                                    Re-session Created
                                </div>
                                <div class="small fw-semibold mb-2 text-danger"
                                     invisible="state != 'Cancel' or session_ids">
                                    <i class="fa fa-times-circle me-1"/>
                                    Rejected
                                </div>
                                <div class="small fw-semibold mb-2 text-danger" invisible="rejected_lines_count == 0">
                                    <i class="fa fa-ban me-1"/>
                                    Rejected Lines:
                                    <field name="rejected_lines_count"/>
                                </div>
                                <div class="small fw-semibold mb-2 text-success" invisible="state != 'Done'">
                                    <i class="fa fa-check-circle me-1"/>
                                    Completed
                                </div>

                                <div class="small text-muted mb-2">
                                    <i class="fa fa-clock-o me-1"/>
                                    <field name="time_taken"/>
                                </div>
                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>

        <record id="inventory_count_session_search_view" model="ir.ui.view">
            <field name="name">.inventory_count_session.search</field>
            <field name="model">setu.inventory.count.session</field>
            <field name="arch" type="xml">
                <search string="Inventory Count Session">
                    <field name="name" string="Name"
                           filter_domain="['|',('name','ilike',self),('user_ids','ilike',self)]"/>
                    <field name="user_ids" string="User"
                           filter_domain="[('user_ids','ilike',self)]"/>
                    <field name="assigned_location_ids"/>
                    <field name="warehouse_id"/>
                    <field name="session_submit_date"/>
                    <filter string="Draft" name="draft" domain="[('state','=','Draft')]"/>
                    <filter string="Pending" name="pending" domain="[('state','=','In Progress')]"/>
                    <filter string="Rejected" name="rejected" domain="[('state','=','Cancel')]"/>
                    <filter string="Done" name="done" domain="[('state','=','Done')]"/>
                    <separator/>
                    <group>
                        <filter string="State" name="state" domain="[]"
                                context="{'group_by':'state'}"/>
                        <filter string="Assigned Locations" name="group_by_assigned_location"
                                context="{'group_by':'assigned_location_ids'}"/>
                        <filter string="Warehouse" name="group_by_warehouse" context="{'group_by':'warehouse_id'}"/>
                        <filter string="User" name="group_by_user" context="{'group_by':'user_ids'}"/>
                        <filter string="Count" name="group_by_count" context="{'group_by':'inventory_count_id'}"/>
                        <filter string="Date" name="date" domain="[]" context="{'group_by': 'session_submit_date'}"
                                help="Date by Month"/>
                    </group>
                </search>
            </field>
        </record>


<?xml version="1.0" encoding="utf-8"?>
<templates xml:space="preserve">

    <t t-name="SetuInventoryDashboard" owl="1">
        <div class="container-fluid p-3">
            <!-- Header Section -->
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2>Inventory Count Dashboard</h2>
                <div class="d-flex gap-2">
                    <!-- Date Filters -->
                    <div class="input-group input-group-sm" style="width: 250px;">
                        <span class="input-group-text">From</span>
                        <input type="date" class="form-control" t-ref="startDate" id="startDate"/>
                    </div>
                    <div class="input-group input-group-sm" style="width: 250px;">
                        <span class="input-group-text">To</span>
                        <input type="date" class="form-control" t-ref="endDate" id="endDate"/>
                    </div>

                    <!-- Warehouse Filter -->
                    <select class="form-select form-select-sm" style="width: 200px;" t-ref="warehouseFilter" id="warehouseFilter">
                        <option value="">All Warehouses</option>
                    </select>

                    <!-- User Filter -->
                    <select class="form-select form-select-sm" style="width: 200px;" t-ref="userFilter" id="userFilter">
                        <option value="">All Users</option>
                    </select>
                </div>
            </div>

            <!-- Loading State -->
            <t t-if="dashboardData.isLoading">
                <div class="text-center p-5">
                    <div class="spinner-border text-primary" role="status">
                        <span class="visually-hidden">Loading...</span>
                    </div>
                    <p class="mt-2">Loading dashboard data...</p>
                </div>
            </t>

            <!-- Error State -->
            <t t-if="dashboardData.hasError and not dashboardData.isLoading">
                <div class="alert alert-danger">
                    <h5>Unable to load dashboard data</h5>
                    <p>Please check your connection and try again.</p>
                    <button class="btn btn-sm btn-outline-danger" t-on-click="initializeDashboard">
                        Retry
                    </button>
                </div>
            </t>

            <!-- Dashboard Content -->
            <t t-if="not dashboardData.isLoading and not dashboardData.hasError">
                <!-- Dashboard Metrics -->
                <div class="row">
                    <!-- Metric Cards -->
                    <div class="col-xl-2 col-md-4 col-sm-6 mb-3">
                        <div class="card bg-primary text-white">
                            <div class="card-body">
                                <h6 class="card-title">Sessions Completed</h6>
                                <h3 t-esc="dashboardData.totalSessionsCompleted" class="mb-0"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4 col-sm-6 mb-3">
                        <div class="card bg-success text-white">
                            <div class="card-body">
                                <h6 class="card-title">Avg Time/Session</h6>
                                <h3 t-esc="dashboardData.avgTimePerSession" class="mb-0"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4 col-sm-6 mb-3">
                        <div class="card bg-info text-white">
                            <div class="card-body">
                                <h6 class="card-title">Products Counted</h6>
                                <h3 t-esc="formatNumber(dashboardData.totalProductsCounted)" class="mb-0"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4 col-sm-6 mb-3">
                        <div class="card bg-warning text-dark">
                            <div class="card-body">
                                <h6 class="card-title">Global Accuracy</h6>
                                <h3 t-esc="formatPercentage(dashboardData.globalAccuracy)" class="mb-0"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4 col-sm-6 mb-3">
                        <div class="card bg-danger text-white">
                            <div class="card-body">
                                <h6 class="card-title">Discrepancy Qty</h6>
                                <h3 t-esc="formatNumber(dashboardData.totalDiscrepancyQty)" class="mb-0"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-xl-2 col-md-4 col-sm-6 mb-3">
                        <div class="card bg-secondary text-white">
                            <div class="card-body">
                                <h6 class="card-title">Pending Approvals</h6>
                                <h3 t-esc="dashboardData.approvalsPending" class="mb-0"/>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Charts Section -->
                <div class="row mt-4">
                    <div class="col-lg-6 col-md-12 mb-4">
                        <div class="card h-100">
                            <div class="card-header">
                                <h5 class="card-title mb-0">
                                    <i class="fa fa-users me-2"></i>User Accuracy
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container" style="position: relative; height: 300px;">
                                    <canvas id="chart_users_accuracy" t-ref="chart_users_accuracy"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-6 col-md-12 mb-4">
                        <div class="card h-100">
                            <div class="card-header">
                                <h5 class="card-title mb-0">
                                    <i class="fa fa-line-chart me-2"></i>Discrepancy Trend
                                </h5>
                            </div>
                            <div class="card-body">
                                <div class="chart-container" style="position: relative; height: 300px;">
                                    <canvas id="chart_discrepancy_trend" t-ref="chart_discrepancy_trend"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Tables Section -->
                <div class="row mt-4">
                    <!-- Open Sessions Table -->
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">
                                    <i class="fa fa-clock-o me-2"></i>Open Sessions
                                </h5>
                                <span class="badge bg-warning" t-esc="tableData.openSessions.length"/>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive" style="max-height: 300px;">
                                    <table class="table table-hover table-striped mb-0">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th scope="col">Session Name</th>
                                                <th scope="col">Warehouse</th>
                                                <th scope="col">Progress</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="tableData.openSessions.length === 0">
                                                <tr>
                                                    <td colspan="3" class="text-center text-muted py-3">
                                                        No open sessions
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-else="">
                                                <t t-foreach="tableData.openSessions" t-as="session" t-key="session.id">
                                                    <tr style="cursor: pointer;" t-on-click="() => this.openSession(session.id)">
                                                        <td>
                                                            <strong t-esc="session.name"/>
                                                        </td>
                                                        <td t-esc="session.warehouse"/>
                                                        <td>
                                                            <div class="progress" style="height: 6px;">
                                                                <div class="progress-bar"
                                                                     t-att-class="session.progress >= 80 ? 'bg-success' : session.progress >= 50 ? 'bg-warning' : 'bg-info'"
                                                                     t-att-style="'width: ' + session.progress + '%;'"
                                                                     role="progressbar"
                                                                     t-att-aria-valuenow="session.progress"
                                                                     aria-valuemin="0"
                                                                     aria-valuemax="100">
                                                                </div>
                                                            </div>
                                                            <small class="text-muted" t-esc="session.progress + '%'"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Adjustments Table -->
                    <div class="col-lg-4 col-md-6 mb-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">
                                    <i class="fa fa-exchange me-2"></i>Recent Adjustments
                                </h5>
                                <span class="badge bg-info" t-esc="tableData.recentAdjustments.length"/>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive" style="max-height: 300px;">
                                    <table class="table table-hover table-striped mb-0">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th scope="col">Product</th>
                                                <th scope="col">Expected</th>
                                                <th scope="col">Counted</th>
                                                <th scope="col">Difference</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="tableData.recentAdjustments.length === 0">
                                                <tr>
                                                    <td colspan="4" class="text-center text-muted py-3">
                                                        No recent adjustments
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-else="">
                                                <t t-foreach="tableData.recentAdjustments" t-as="adjustment" t-key="adjustment.id">
                                                    <tr style="cursor: pointer;" t-on-click="() => this.openAdjustment(adjustment.id)">
                                                        <td>
                                                            <div>
                                                                <strong t-esc="adjustment.product_name"/>
                                                                <br/>
                                                                <small class="text-muted" t-esc="adjustment.product_code"/>
                                                            </div>
                                                        </td>
                                                        <td t-esc="formatNumber(adjustment.expected_qty)"/>
                                                        <td t-esc="formatNumber(adjustment.counted_qty)"/>
                                                        <td>
                                                            <span t-att-class="adjustment.difference >= 0 ? 'text-success' : 'text-danger'">
                                                                <t t-if="adjustment.difference >= 0">+</t>
                                                                <span t-esc="formatNumber(adjustment.difference)"/>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- High Risk Products Table -->
                    <div class="col-lg-4 col-md-12 mb-4">
                        <div class="card h-100">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <h5 class="card-title mb-0">
                                    <i class="fa fa-exclamation-triangle me-2"></i>High Risk Products
                                </h5>
                                <span class="badge bg-danger" t-esc="tableData.highRiskProducts.length"/>
                            </div>
                            <div class="card-body p-0">
                                <div class="table-responsive" style="max-height: 300px;">
                                    <table class="table table-hover table-striped mb-0">
                                        <thead class="table-light sticky-top">
                                            <tr>
                                                <th scope="col">Product</th>
                                                <th scope="col">Discrepancy</th>
                                                <th scope="col">Accuracy</th>
                                                <th scope="col">Risk</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            <t t-if="tableData.highRiskProducts.length === 0">
                                                <tr>
                                                    <td colspan="4" class="text-center text-muted py-3">
                                                        No high risk products
                                                    </td>
                                                </tr>
                                            </t>
                                            <t t-else="">
                                                <t t-foreach="tableData.highRiskProducts" t-as="product" t-key="product.id">
                                                    <tr style="cursor: pointer;" t-on-click="() => this.openProduct(product.id)">
                                                        <td>
                                                            <div>
                                                                <strong t-esc="product.name"/>
                                                                <br/>
                                                                <small class="text-muted" t-esc="product.code"/>
                                                            </div>
                                                        </td>
                                                        <td t-esc="formatNumber(product.discrepancy_count)"/>
                                                        <td>
                                                            <span t-att-class="product.accuracy >= 90 ? 'text-success' : product.accuracy >= 80 ? 'text-warning' : 'text-danger'">
                                                                <span t-esc="formatPercentage(product.accuracy)"/>
                                                            </span>
                                                        </td>
                                                        <td>
                                                            <span t-att-class="product.risk_level === 'high' ? 'badge bg-danger' : product.risk_level === 'medium' ? 'badge bg-warning' : 'badge bg-info'">
                                                                <t t-esc="product.risk_level"/>
                                                            </span>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </t>
        </div>
    </t>

</templates>